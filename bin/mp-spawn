#!/bin/bash
set -e

# ============================================
# mp-spawn: Spawn Claude Code worker in iTerm2
# Worktree creation is handled by /start-task
# ============================================

usage() {
  cat <<EOF
Usage: mp-spawn <task-id> [options]

Options:
  --dir /path/to/project  Project directory (default: current directory)
  --skip-permissions      Skip all permission prompts (--dangerously-skip-permissions)
  --chrome                Enable Chrome browser tools (--chrome)
  --no-chrome             Disable Chrome browser tools
  --help                  Show this help

Note: Handoff context is passed via docs/pending_handoffs/<task-id>.txt files,
written by /dispatch before spawning. The --handoff flag is deprecated.

Examples:
  mp-spawn MoneyPrinter-ajq
  mp-spawn MoneyPrinter-ajq --dir /Users/jneumann/Code/MoneyPrinter
  mp-spawn MoneyPrinter-ajq --skip-permissions --chrome
EOF
  exit 1
}

# Parse arguments
TASK_ID=""
PROJECT_DIR=""
HANDOFF=""
SKIP_PERMS=""
CHROME=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --dir)
      PROJECT_DIR="$2"
      shift 2
      ;;
    --handoff)
      HANDOFF="$2"
      shift 2
      ;;
    --skip-permissions)
      SKIP_PERMS="--dangerously-skip-permissions"
      shift
      ;;
    --chrome)
      CHROME="--chrome"
      shift
      ;;
    --no-chrome)
      CHROME=""
      shift
      ;;
    --help|-h)
      usage
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      if [[ -z "$TASK_ID" ]]; then
        TASK_ID="$1"
      fi
      shift
      ;;
  esac
done

[[ -z "$TASK_ID" ]] && usage

# ============================================
# Project directory: use --dir or default to pwd
# ============================================
if [[ -z "$PROJECT_DIR" ]]; then
  PROJECT_DIR="$(pwd)"
fi

# Resolve to absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

# Verify it's a git repo with beads
if [[ ! -d "$PROJECT_DIR/.git" ]]; then
  echo "Error: $PROJECT_DIR is not a git repository"
  exit 1
fi

if [[ ! -d "$PROJECT_DIR/.beads" ]]; then
  echo "Warning: $PROJECT_DIR has no .beads directory"
fi

echo "Project: $PROJECT_DIR"

# ============================================
# Build the /start-task command
# ============================================
TASK_SHORT=$(echo "$TASK_ID" | cut -d'-' -f2)

# ============================================
# Open new iTerm2 tab via AppleScript
# ============================================
echo "Opening iTerm2 tab for $TASK_ID..."

# Build claude command with flags
CLAUDE_CMD="claude"
[[ -n "$CHROME" ]] && CLAUDE_CMD="$CLAUDE_CMD $CHROME"
[[ -n "$SKIP_PERMS" ]] && CLAUDE_CMD="$CLAUDE_CMD $SKIP_PERMS"

# Use osascript to open a new iTerm2 tab, cd to project dir, and start claude
# After tab is ready, we create a signal file and start claude
# The SessionStart hook claims the signal and processes the queue
# /start-task will handle worktree creation
osascript \
  -e 'tell application "iTerm2"' \
  -e '    activate' \
  -e '    if (count of windows) = 0 then' \
  -e '        create window with default profile' \
  -e '    end if' \
  -e '    tell current window' \
  -e '        create tab with default profile' \
  -e '        tell current session' \
  -e "            write text \"cd '${PROJECT_DIR}'\"" \
  -e '        end tell' \
  -e '    end tell' \
  -e 'end tell'

# Wait for cd to complete
sleep 0.5

# Set tab/session name using iTerm2's native AppleScript property
osascript \
  -e 'tell application "iTerm2"' \
  -e '    tell current window' \
  -e '        tell current session' \
  -e "            set name to \"${TASK_SHORT}\"" \
  -e '        end tell' \
  -e '    end tell' \
  -e 'end tell'

# Create spawn signal file - this tells the hook this is a worker session
# The hook will claim this signal (delete it) and process the queue
# Signal filename includes timestamp and PID for uniqueness
mkdir -p "$PROJECT_DIR/docs/pending_handoffs"
SPAWN_SIGNAL="$PROJECT_DIR/docs/pending_handoffs/.spawn-$(date +%s)-$$"
touch "$SPAWN_SIGNAL"

# Start claude - the SessionStart hook will see the signal and process queue
osascript \
  -e 'tell application "iTerm2"' \
  -e '    tell current window' \
  -e '        tell current session' \
  -e "            write text \"${CLAUDE_CMD}\"" \
  -e '        end tell' \
  -e '    end tell' \
  -e 'end tell'

# Wait for claude to start before returning
sleep 2

echo ""
echo "Worker spawned for $TASK_ID"
echo "Signal: $SPAWN_SIGNAL"
echo ""
echo "The worker will claim the signal and pop its task from the queue on startup."
